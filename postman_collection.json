            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"task_id\": \"t_fail\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{tasks_base_url}}/v1/jobs/process-task",
          "host": [
            "{{tasks_base_url}}"
          ],
          "path": [
            "v1",
            "jobs",
            "process-task"
          ]
        }
      },
      "response": []
