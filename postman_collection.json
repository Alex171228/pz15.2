{
  "info": {
    "_postman_id": "6f0f9f22-8f56-4c3f-b8f4-8d42c6d8e7a1",
    "name": "PZ14 Task Queue",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "auth_base_url",
      "value": "http://localhost:8081"
    },
    {
      "key": "tasks_base_url",
      "value": "http://localhost:8082"
    },
    {
      "key": "access_token",
      "value": "demo-token"
    }
  ],
  "item": [
    {
      "name": "1. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "if (jsonData.access_token) {",
              "    pm.collectionVariables.set('access_token', jsonData.access_token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"student\",\n  \"password\": \"student\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{auth_base_url}}/v1/auth/login",
          "host": [
            "{{auth_base_url}}"
          ],
          "path": [
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{tasks_base_url}}/health",
          "host": [
            "{{tasks_base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "3. Process Task Success",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 202', function () {",
              "    pm.response.to.have.status(202);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "if (jsonData.message_id) {",
              "    pm.collectionVariables.set('last_success_message_id', jsonData.message_id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"task_id\": \"t_001\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{tasks_base_url}}/v1/jobs/process-task",
          "host": [
            "{{tasks_base_url}}"
          ],
          "path": [
            "v1",
            "jobs",
            "process-task"
          ]
        }
      },
      "response": []
    },
    {
      "name": "4. Process Task Fail",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 202', function () {",
              "    pm.response.to.have.status(202);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "if (jsonData.message_id) {",
              "    pm.collectionVariables.set('last_fail_message_id', jsonData.message_id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
